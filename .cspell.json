{
  "$schema": "https://raw.githubusercontent.com/streetsidesoftware/cspell/main/cspell.schema.json",
  "version": "0.2",
  "language": "en",
  "languageId": "typescript,javascript",
  "dictionaries": [
    "powershell",
    "typescript",
    "node"
  ],
  "useGitignore": true,
  "ignorePaths": [
    ".gitignore",
    "*.d.ts"
  ],
  "words": [
    "dcmitype",
    "dcterms",
    "dotm",
    "lopdf",
    "msvc",
    "nsis",
    "nums",
    "rsplit",
    "tauri",
    "vaul",
    "zhengxs"
  ],
  "allowCompoundWords": true,
  "overrides": []
}
