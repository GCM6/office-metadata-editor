{
  "hooks": {
    "UserPromptSubmit": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash \"$CLAUDE_PROJECT_DIR/.claude/hooks/seo-geo-prompt.sh\"",
            "statusMessage": "Checking SEO/GEO relevance"
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "Edit|Write|MultiEdit",
        "hooks": [
          {
            "type": "command",
            "command": "bash \"$CLAUDE_PROJECT_DIR/.claude/hooks/seo-geo-edit.sh\"",
            "statusMessage": "Checking SEO file rules"
          }
        ]
      }
    ]
  }
}
